DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE
BLOB_READ_WRITE_TOKEN=YOUR_BLOB_READ_WRITE_TOKEN_HERE

# SEO: canonical origin for Open Graph, sitemap, and JSON-LD (no trailing slash)
# Example: https://www.yoursite.com
NEXT_PUBLIC_SITE_URL=

# Set to 1 on staging to disallow indexing (preview deploys on Vercel are noindex by default)
# NEXT_PUBLIC_NOINDEX=1
